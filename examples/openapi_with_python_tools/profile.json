{
  "$schema": "https://schemas.bauer-group.com/mcp-profile/v1.json",
  "id": "petstore-plus",
  "display_name": "BG Petstore+ (Tier-2 demo)",
  "instructions": "Tier-2 demo: an OpenAPI surface PLUS a few hand-written composite tools.",
  "backend": {
    "base_url": "https://petstore.example.com",
    "api_base_path": ""
  },
  "auth": {
    "inbound": { "mode": "none" },
    "outbound": { "type": "bearer_env", "value_from_env": "PETSTORE_TOKEN" }
  },
  "tools": [
    {
      "source": "openapi",
      "spec": { "source": "petstore-mini.json" },
      "name_overrides": { "GET /pets": "list_pets", "POST /pets": "create_pet" },
      "annotations": "by_http_method"
    },
    { "source": "python", "register": "extra_tools:register_extras" }
  ]
}
